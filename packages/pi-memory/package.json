{
  "name": "@josorio/pi-memory",
  "version": "0.1.0",
  "description": "Persistent cross-session memory for pi agents — ported from OpenClaw memory-lancedb",
  "keywords": ["pi-package", "pi-memory", "ai-agent", "memory"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
